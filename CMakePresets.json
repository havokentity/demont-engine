{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 27, "patch": 0 },
  "configurePresets": [
    {
      "name": "mac-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "mac-debug",
      "displayName": "Mac · Debug",
      "inherits": "mac-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PT_ENABLE_TRACY": "ON"
      }
    },
    {
      "name": "mac-release",
      "displayName": "Mac · Release",
      "inherits": "mac-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PT_ENABLE_TRACY": "OFF"
      }
    },

    {
      "name": "win-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "cl",
        "CMAKE_CXX_COMPILER": "cl"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "hostOS": [ "Windows" ]
        }
      }
    },
    {
      "name": "win-debug",
      "displayName": "Windows · Debug (MSVC)",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PT_ENABLE_TRACY":  "ON"
      }
    },
    {
      "name": "win-release",
      "displayName": "Windows · Release (MSVC)",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PT_ENABLE_TRACY":  "OFF"
      }
    },
    {
      "name": "win-clang-debug",
      "displayName": "Windows · Debug (clang-cl)",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_BUILD_TYPE":   "Debug",
        "PT_ENABLE_TRACY":    "ON"
      }
    },

    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux · Debug",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PT_ENABLE_TRACY":  "ON"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux · Release",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PT_ENABLE_TRACY":  "OFF"
      }
    }
  ],
  "buildPresets": [
    { "name": "mac-debug",       "configurePreset": "mac-debug",       "jobs": 0 },
    { "name": "mac-release",     "configurePreset": "mac-release",     "jobs": 0 },
    { "name": "win-debug",       "configurePreset": "win-debug",       "jobs": 0 },
    { "name": "win-release",     "configurePreset": "win-release",     "jobs": 0 },
    { "name": "win-clang-debug", "configurePreset": "win-clang-debug", "jobs": 0 },
    { "name": "linux-debug",     "configurePreset": "linux-debug",     "jobs": 0 },
    { "name": "linux-release",   "configurePreset": "linux-release",   "jobs": 0 }
  ]
}
